# ---- Supabase (server-side; service role bypasses RLS — keep secret) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Anthropic Claude (CV extraction, job matching, outreach) ----
ANTHROPIC_API_KEY=sk-ant-your-key

# ---- Adzuna job search (https://developer.adzuna.com) ----
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
# Default Adzuna country code (2-letter, e.g. gb, us, au)
ADZUNA_COUNTRY=gb

# ---- Reed job search, optional (https://www.reed.co.uk/developers) ----
# UK-focused. Searches run across every configured source and de-duplicate.
REED_API_KEY=your-reed-api-key

# ---- JSearch, optional (RapidAPI) ----
# Aggregates Google for Jobs: LinkedIn, Indeed, Glassdoor, ZipRecruiter, etc.
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch (free tier is limited;
# each run uses ~1 request per target role).
JSEARCH_API_KEY=your-rapidapi-key

# ---- ATS-direct, optional ----
# Pull roles straight from companies' own boards (Greenhouse / Lever / Ashby).
# Comma-separated provider:token[:Display Name]; token is the careers-URL slug.
# ATS_BOARDS=greenhouse:stripe:Stripe,lever:netflix,ashby:ramp:Ramp
